[flake8]
max-line-length = 100
extend-ignore = 
    # Line break before binary operator (conflicts with black)
    W503,
    # Line break after binary operator (conflicts with black)  
    W504,
    # Whitespace before ':' (conflicts with black)
    E203
    # Trailing whitespaces
    W291
    # Unused local variable
    F841
    # Unused import
    F401
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    *.egg-info,
    .venv,
    venv
